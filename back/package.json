  "main": "dist/index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w",
    "start": "npm run build && concurrently \"npm run build:watch\" \"npm run serve:watch\"",
    "start:prod": "npm run build && node dist/index.js",
    "serve": "node dist/index.js",
    "serve:watch": "nodemon dist/index.js",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write ."
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "concurrently": "^7.2.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^2.0.19",
    "prettier": "^3.3.2",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.1",
