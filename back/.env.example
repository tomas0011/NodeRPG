# Variables de entorno del backend (NodeRPG). Copia este archivo a `back/.env`
# y rellena los valores reales. NUNCA subas `back/.env` al repo (está gitignored).
# En producción (Render) estas variables se cargan en el dashboard del servicio,
# NO en un archivo: el `.env` no se copia a la imagen Docker.

# Cadena de conexión a MongoDB Atlas (mongodb+srv://...). REQUERIDA.
# Obtenla en Atlas → Database → Connect → Drivers. Es un secreto: en Render
# márcala como variable sin sincronizar (sync: false) y pégala en el dashboard.
MONGO_CONNECTION_STRING='mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/noderpg?retryWrites=true&w=majority'

# Puerto HTTP del servidor. OPCIONAL: si no se define, usa 3001 (dev local).
# En Render NO hace falta setearla: la plataforma inyecta PORT automáticamente.
# PORT=3001

# Origen(es) permitido(s) por CORS. OPCIONAL.
# - Si NO se define (dev local): se permiten todos los orígenes (comportamiento actual).
# - Si se define: se restringe a ese origen. Acepta una lista separada por comas.
# En prod, ponlo a la URL del frontend en Vercel, p. ej:
# CORS_ORIGIN='https://noderpg.vercel.app'
# o varios: CORS_ORIGIN='https://noderpg.vercel.app,https://noderpg-preview.vercel.app'
# CORS_ORIGIN=
